{
  "name": "virtual-display-chromium-streamer",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "main": "src/main.js",
  "scripts": {
    "build": "esbuild src/host-renderer.js --bundle --platform=browser --outfile=dist/host-renderer.js && esbuild src/viewer.js --bundle --platform=browser --outfile=dist/viewer.js",
    "start": "npm run build && electron src/main.js",
    "test": "node --test test/*.test.js",
    "check": "node --check src/main.js && node --check src/preload.js && node --check src/quality-policy.js && npm test"
  },
  "dependencies": {
    "electron": "43.1.1",
    "express": "^5.1.0",
    "pixelmatch": "^7.1.0",
    "simple-peer": "^9.11.1",
    "socket.io": "^4.8.1"
  },
  "devDependencies": { "esbuild": "^0.25.6" }
}
